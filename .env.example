# Path to the video library root. Subfolders Movies/ and TV/ (or Series/Shows) are auto-classified.
LIBRARY_ROOT=/Volumes/Extreme SSD/Perflix Media

# Public URL the app is reached at (used for WebAuthn origin and CORS).
# Dev: http://localhost:5173 — Prod: https://perflix.<your-domain>
PUBLIC_URL=http://localhost:5173

# WebAuthn relying-party config.
# RP_ID must be the bare domain (no scheme, no path). For localhost dev use "localhost".
RP_ID=localhost
RP_NAME=Perflix

# Server bind. Stays on loopback — Cloudflare Tunnel reaches us via localhost.
HOST=127.0.0.1
PORT=7000

# TMDb v4 Read Access Token (Bearer). Get it at https://www.themoviedb.org/settings/api
# (Use the "API Read Access Token" — NOT the legacy v3 API key.)
TMDB_ACCESS_TOKEN=

# OpenSubtitles REST API v1. Get a key at https://www.opensubtitles.com/consumers
# Enable "VIP / dev" mode for 100 downloads/day (free tier is 5/day).
OPENSUBS_API_KEY=
OPENSUBS_USER_AGENT=Perflix v0.1

# 32-byte random hex secrets. Generate each with: openssl rand -hex 32
SESSION_SECRET=
SIGNING_SECRET=

# HLS segment disk cache cap (bytes). Default 15 GB.
HLS_CACHE_BYTES=644245094400

# Optional: ffmpeg with libzimg for HDR tone-mapping. On macOS, Perflix auto-uses
# /opt/homebrew/opt/ffmpeg-full/bin/ffmpeg when present (brew install ffmpeg-full).
# FFMPEG_PATH=
